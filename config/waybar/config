{
    "layer": "top",
    "position": "bottom",
    "spacing": 8,
    "reload_style_on_change": true,
    "modules-left": ["niri/workspaces"],
    "modules-center": [""],
    "modules-right": ["mpd", "network",  "memory", "cpu", "temperature", "battery", "pulseaudio", "clock#date", "clock"],
    "mpd": {
	    "format": "{artist} - {album} - {title} - ({elapsedTime:%M:%S}/{totalTime:%M:%S}) {songPosition}/{queueLength}",
	    "format-stopped": ""

    },
    "network": {
	    "interface": "wlp2s0",
	    "format": "{ifname}",
	    "format-wifi": "{essid} {signalStrength}% ▲{bandwidthUpBits}▼{bandwidthDownBits}"
//	    "format-ethernet": "{ifname}",
//	    "format-disconnected": "disconnected"
    },
    "memory": {
	    "format": "{used:0.0f}/{total:0.0f}G"
    },
    "cpu": {
	    "interval": 10,
	    "format": "cpu {usage}%"
    	    //"format": "{icon0} {icon1} {icon2} {icon3} {icon4} {icon5} {icon6} {icon7}",
     	    //"format-icons": ["▁", "▂", "▃", "▄", "▅", "▆", "▇", "█"]
    },
    "pulseaudio": {
	    "format": "vol {volume}"
    },
    "clock": {
	    "format": "{:%H:%M}"
    },
    "clock#date": {
	    "format": "{:%F}"
    },
    "battery": {
        "format": "◈{capacity}%"
    }
}
